variant: fcos
version: 1.6.0

passwd:
  groups:
    - name: podman
  users:
    - name: core
      ssh_authorized_keys_local:
        - ignition/files/authorized_keys
      groups:
        - wheel
        - sudo
    - name: nazar-agent
      uid: 900
      system: true
      groups:
        - podman
      shell: /usr/sbin/nologin
      home_dir: /var/lib/nazar

storage:
  directories:
    - path: /var/lib/nazar
      user:
        name: nazar-agent
      group:
        name: nazar-agent
    - path: /var/lib/nazar/objects
      user:
        name: nazar-agent
      group:
        name: nazar-agent
    - path: /var/lib/nazar/conduit
      user:
        name: nazar-agent
      group:
        name: nazar-agent
    - path: /var/lib/nazar/matrix-storage
      user:
        name: nazar-agent
      group:
        name: nazar-agent
    - path: /var/lib/nazar/evolution
      user:
        name: nazar-agent
      group:
        name: nazar-agent
    - path: /etc/nazar
    - path: /usr/local/share/nazar
    - path: /usr/local/share/nazar/persona
    - path: /usr/local/share/nazar/skills

  files:
    # --- CLI and scripts ---
    - path: /usr/local/bin/nazar
      mode: 0755
      contents:
        local: scripts/nazar
    - path: /usr/local/bin/nazar-setup
      mode: 0755
      contents:
        local: scripts/nazar-setup.sh
    - path: /usr/local/bin/nazar-object
      mode: 0755
      contents:
        local: scripts/nazar-object.sh
    - path: /usr/local/bin/nazar-evolve
      mode: 0755
      contents:
        local: scripts/nazar-evolve.sh
    - path: /usr/local/bin/nazar-vm
      mode: 0755
      contents:
        local: scripts/nazar-vm.sh
    - path: /usr/local/bin/nazar-deploy
      mode: 0755
      contents:
        local: scripts/nazar-deploy.sh

    # --- Configuration ---
    - path: /etc/nazar/nazar.yaml
      mode: 0644
      contents:
        local: ignition/files/nazar.yaml.default
    - path: /etc/sudoers.d/nazar-evolve
      mode: 0440
      contents:
        local: ignition/files/sudoers-nazar-evolve
    - path: /etc/sudoers.d/core-wheel
      mode: 0440
      contents:
        inline: |
          %wheel ALL=(ALL) NOPASSWD: ALL

    # --- System documentation ---
    - path: /usr/local/share/nazar/SYSTEM.md
      mode: 0644
      contents:
        local: ignition/files/SYSTEM.md

    # --- Persona files ---
    - path: /usr/local/share/nazar/persona/SOUL.md
      mode: 0644
      contents:
        local: persona/SOUL.md
    - path: /usr/local/share/nazar/persona/BODY.md
      mode: 0644
      contents:
        local: persona/BODY.md
    - path: /usr/local/share/nazar/persona/FACULTY.md
      mode: 0644
      contents:
        local: persona/FACULTY.md
    - path: /usr/local/share/nazar/persona/SKILL.md
      mode: 0644
      contents:
        local: persona/SKILL.md

    # --- Skills ---
    - path: /usr/local/share/nazar/skills/claude-consult/SKILL.md
      mode: 0644
      contents:
        local: skills/claude-consult/SKILL.md
    - path: /usr/local/share/nazar/skills/object-journal/SKILL.md
      mode: 0644
      contents:
        local: skills/object-journal/SKILL.md
    - path: /usr/local/share/nazar/skills/object-task/SKILL.md
      mode: 0644
      contents:
        local: skills/object-task/SKILL.md
    - path: /usr/local/share/nazar/skills/heartbeat/SKILL.md
      mode: 0644
      contents:
        local: skills/heartbeat/SKILL.md
    - path: /usr/local/share/nazar/skills/object-note/SKILL.md
      mode: 0644
      contents:
        local: skills/object-note/SKILL.md
    - path: /usr/local/share/nazar/skills/install-nazar/SKILL.md
      mode: 0644
      contents:
        local: skills/install-nazar/SKILL.md
    - path: /usr/local/share/nazar/skills/hephaestus-maintainer/SKILL.md
      mode: 0644
      contents:
        local: skills/hephaestus-maintainer/SKILL.md
    - path: /usr/local/share/nazar/skills/themis-reviewer/SKILL.md
      mode: 0644
      contents:
        local: skills/themis-reviewer/SKILL.md
    - path: /usr/local/share/nazar/skills/tdd/SKILL.md
      mode: 0644
      contents:
        local: skills/tdd/SKILL.md
    - path: /usr/local/share/nazar/skills/matrix-setup/SKILL.md
      mode: 0644
      contents:
        local: skills/matrix-setup/SKILL.md
    - path: /usr/local/share/nazar/skills/artifact-reviewer/SKILL.md
      mode: 0644
      contents:
        local: skills/artifact-reviewer/SKILL.md
    - path: /usr/local/share/nazar/skills/object-evolution/SKILL.md
      mode: 0644
      contents:
        local: skills/object-evolution/SKILL.md
    - path: /usr/local/share/nazar/skills/nazar-runtime/SKILL.md
      mode: 0644
      contents:
        local: skills/nazar-runtime/SKILL.md
    - path: /usr/local/share/nazar/skills/athena-technical-architect/SKILL.md
      mode: 0644
      contents:
        local: skills/athena-technical-architect/SKILL.md
    - path: /usr/local/share/nazar/skills/persona-harvest/SKILL.md
      mode: 0644
      contents:
        local: skills/persona-harvest/SKILL.md

    # --- Lingering (enable user services for nazar-agent) ---
    - path: /var/lib/systemd/linger/nazar-agent
      mode: 0644

    # --- Zincati auto-update strategy ---
    - path: /etc/zincati/config.d/55-updates-strategy.toml
      mode: 0644
      contents:
        inline: |
          [updates]
          strategy = "periodic"
          [[updates.periodic.window]]
          days = [ "Sat", "Sun" ]
          start_time = "02:00"
          length_minutes = 240

    # --- Hostname ---
    - path: /etc/hostname
      mode: 0644
      overwrite: true
      contents:
        inline: nazar-box

systemd:
  units:
    # --- First-boot RPM layering ---
    - name: nazar-rpm-layer.service
      enabled: true
      contents_local: ignition/files/nazar-rpm-layer.service

    # --- First-boot setup (after RPM layer reboot) ---
    - name: nazar-setup.service
      enabled: true
      contents_local: ignition/files/nazar-setup.service

    # --- Tailscale ---
    - name: tailscaled.service
      enabled: true
