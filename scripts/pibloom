#!/usr/bin/env bash
set -euo pipefail

# pibloom — CLI wrapper for the piBloom AI companion system.
#
# Usage:
#   pibloom apply [--dry-run]    Apply config, generate Quadlet files, reload systemd
#   pibloom status               Show running services and object store stats
#   pibloom update               Pull latest remote container images (local images via pibloom deploy --images)
#   pibloom rollback             Show bootc deployments and rollback instructions
#   pibloom deploy [flags]       Deploy changes to dev VM
#   pibloom vm <cmd>             Dev VM lifecycle (create/start/stop/destroy/ssh)
#   pibloom evolve <cmd> ...     Container evolution lifecycle
#   pibloom object <cmd> ...     Object store CRUD
#   pibloom signal <cmd>         Signal account setup (check/link/register/verify/accounts)
#   pibloom pi [args]            Launch Pi agent with persona + skills
#   pibloom setup                Interactive first-time setup (Pi with install-pibloom skill)
#   pibloom                      Interactive Pi session (no args)

PIBLOOM_SKILLS_DIR="${PIBLOOM_SKILLS_DIR:-/usr/local/share/pibloom/skills}"
PIBLOOM_PERSONA_DIR="${PIBLOOM_PERSONA_DIR:-/usr/local/share/pibloom/persona}"

cmd="${1:-}"
shift 2>/dev/null || true

case "$cmd" in
  apply)
    pibloom-core setup "$@"
    # Reload systemd so it picks up new/changed Quadlet files
    if [[ ! " $* " =~ " --dry-run " ]]; then
      sudo systemctl daemon-reload
      echo "systemd reloaded."
    fi
    ;;

  status)
    echo "=== bootc Status ==="
    sudo bootc status 2>/dev/null || echo "(bootc not available)"
    echo ""
    echo "=== piBloom Services ==="
    systemctl list-units 'pibloom-*' --no-pager 2>/dev/null || echo "(no pibloom services found)"
    echo ""
    echo "=== Object Store ==="
    objects_dir="${PIBLOOM_OBJECTS_DIR:-/var/lib/pibloom/objects}"
    if [[ -d "$objects_dir" ]]; then
      count=$(find "$objects_dir" -name '*.md' -type f 2>/dev/null | wc -l)
      echo "Objects: $count"
      for type_dir in "$objects_dir"/*/; do
        [[ -d "$type_dir" ]] || continue
        type_name=$(basename "$type_dir")
        type_count=$(find "$type_dir" -name '*.md' -type f 2>/dev/null | wc -l)
        echo "  $type_name: $type_count"
      done
    else
      echo "Objects directory not found: $objects_dir"
    fi
    ;;

  update)
    echo "=== OS Update ==="
    echo "Checking for bootc OS updates..."
    sudo bootc update 2>/dev/null || echo "(bootc update not available — running outside bootc?)"
    echo "Note: OS updates take effect after reboot (sudo systemctl reboot)"
    echo ""
    echo "=== Container Images ==="
    echo "Pulling latest container images..."
    echo "Done. Restart services with: systemctl restart pibloom-*"
    ;;

  rollback)
    echo "=== bootc Deployments ==="
    sudo bootc status 2>/dev/null || echo "(bootc not available)"
    echo ""
    echo "To rollback the OS to a previous deployment:"
    echo "  sudo bootc rollback"
    echo "  sudo systemctl reboot"
    echo ""
    echo "To rollback a container evolution:"
    echo "  pibloom evolve rollback <slug>"
    ;;

  deploy)
    exec pibloom-deploy "$@"
    ;;

  vm)
    exec pibloom-vm "$@"
    ;;

  evolve)
    exec pibloom-core evolve "$@"
    ;;

  object)
    exec pibloom-core object "$@"
    ;;

  signal)
    exec pibloom-signal-setup "$@"
    ;;

  pi)
    exec pi "$@"
    ;;

  setup)
    exec pi --skill "${PIBLOOM_SKILLS_DIR}/install-pibloom"
    ;;

  "")
    # No args — interactive Pi session
    exec pi
    ;;

  *)
    echo "Error: unknown command: $cmd" >&2
    echo "" >&2
    echo "Usage: pibloom <apply|status|update|rollback|deploy|vm|evolve|object|signal|pi|setup>" >&2
    exit 1
    ;;
esac
