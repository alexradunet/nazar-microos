# /etc/pibloom/pibloom.yaml — piBloom system configuration
# Edit this file, then run: pibloom apply

hostname: pibloom-box
primary_user: alex
timezone: UTC

heartbeat:
  interval: 30m

signal:
  phone_number: "+15551234567"
  allowed_contacts: ["+15559876543", "+15558765432"]

ui:
  port: 3000

agent:
  skills_dir: /usr/local/share/pibloom/skills
  persona_dir: /usr/local/share/pibloom/persona

evolution:
  max_containers_per_evolution: 5

firewall:
  restrict_to_tailscale: true
  open_ports: []
