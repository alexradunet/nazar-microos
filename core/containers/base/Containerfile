# To update digest: see https://hub.docker.com/_/node/tags?name=22-slim
FROM docker.io/node:22-slim@sha256:7cc56ef285a8568121537d17b05e72128f01b89c54607b51acf084a50ef483f3

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates \
  && rm -rf /var/lib/apt/lists/*

# Create nazar user
RUN useradd -m -u 900 -s /bin/bash nazar

# Set up workspace
WORKDIR /app

# Copy all workspace package.json files for layer caching, then install all deps
COPY package.json package-lock.json ./
COPY core/package.json core/
COPY bridges/signal/package.json bridges/signal/
COPY bridges/web/package.json bridges/web/
COPY bridges/whatsapp/package.json bridges/whatsapp/
RUN npm ci

# Copy and build core (npm ci symlinks node_modules/@nazar/core here)
# Remove stale tsbuildinfo (tracked in git) so tsc emits fresh dist/
COPY core/ core/
RUN rm -f core/tsconfig.tsbuildinfo \
  && npm -w core run build

USER nazar
