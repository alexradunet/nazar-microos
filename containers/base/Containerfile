FROM docker.io/node:22-slim

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    jq curl ca-certificates \
  && rm -rf /var/lib/apt/lists/*

# Install yq-go from GitHub releases
ARG YQ_VERSION=v4.44.1
RUN curl -fsSL "https://github.com/mikefarah/yq/releases/download/${YQ_VERSION}/yq_linux_$(dpkg --print-architecture)" \
    -o /usr/local/bin/yq && chmod +x /usr/local/bin/yq

# Create nazar user
RUN useradd -m -s /bin/bash nazar

# Set up workspace
WORKDIR /app

# Copy package files first for layer caching
COPY package.json package-lock.json ./
COPY packages/nazar-core/package.json packages/nazar-core/
RUN npm ci --workspace=packages/nazar-core

# Copy and build nazar-core
COPY packages/nazar-core/ packages/nazar-core/
RUN npm -w packages/nazar-core run build

USER nazar
