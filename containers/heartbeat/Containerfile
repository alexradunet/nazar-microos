FROM nazar-base

USER root

# nazar-object shim (delegates to nazar-core built in nazar-base)
RUN printf '#!/usr/bin/env bash\nexec node /app/packages/nazar-core/dist/cli.js object "$@"\n' > /usr/local/bin/nazar-object \
    && chmod +x /usr/local/bin/nazar-object

# Copy heartbeat skill and persona (use /usr/local/share to match OS image convention)
COPY agent/skills/heartbeat/ /usr/local/share/nazar/skills/heartbeat/
COPY agent/persona/ /usr/local/share/nazar/persona/

# Copy entrypoint
COPY containers/heartbeat/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

USER nazar

ENV NAZAR_OBJECTS_DIR=/data/objects
ENV NAZAR_SKILLS_DIR=/usr/local/share/nazar/skills
ENV NAZAR_PERSONA_DIR=/usr/local/share/nazar/persona

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
