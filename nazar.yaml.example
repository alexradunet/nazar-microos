# /etc/nazar/nazar.yaml — Nazar system configuration
# Edit this file, then run: nazar apply

hostname: nazar-box
primary_user: alex
timezone: UTC

heartbeat:
  interval: 30m

ttyd:
  port: 7681

signal:
  phone_number: "+15551234567"
  allowed_contacts: ["+15559876543", "+15558765432"]

ui:
  port: 3000

pi:
  skills_dir: /usr/local/share/nazar/skills
  persona_dir: /usr/local/share/nazar/persona

evolution:
  max_containers_per_evolution: 5

firewall:
  restrict_to_tailscale: true
  open_ports: []
