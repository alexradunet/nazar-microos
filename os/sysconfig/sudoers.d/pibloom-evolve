# piBloom Evolution — restricted sudo for container service management.
# NOTE: The pibloom-* wildcard allows starting any unit matching that prefix.
# This is an accepted risk — the evolution install flow validates container
# names (must match /^pibloom-[a-zA-Z0-9][a-zA-Z0-9._-]*$/) and requires
# interactive approval before writing Quadlet files.
pibloom-agent ALL=(root) NOPASSWD: /usr/bin/systemctl daemon-reload
pibloom-agent ALL=(root) NOPASSWD: /usr/bin/systemctl start pibloom-*
pibloom-agent ALL=(root) NOPASSWD: /usr/bin/systemctl stop pibloom-*
pibloom-agent ALL=(root) NOPASSWD: /usr/bin/systemctl restart pibloom-*
pibloom-agent ALL=(root) NOPASSWD: /usr/bin/systemctl is-active pibloom-*
